{
  "name": "zclaw-core",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/adapters/cli/index.js",
  "exports": {
    ".": {
      "import": "./dist/adapters/sdk/index.js",
      "types": "./dist/adapters/sdk/index.d.ts"
    },
    "./react": {
      "import": "./dist/adapters/sdk/react.js",
      "types": "./dist/adapters/sdk/react.d.ts"
    },
    "./server": {
      "import": "./dist/adapters/server/index.js",
      "types": "./dist/adapters/server/index.d.ts"
    }
  },
  "types": "./dist/adapters/sdk/index.d.ts",
  "bin": {
    "zclaw": "dist/adapters/cli/index.js",
    "zclaw-server": "dist/adapters/server/standalone.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/adapters/cli/index.js",
    "server": "node dist/adapters/server/standalone.js",
    "dev": "tsx src/adapters/cli/index.ts",
    "dev:server": "tsx src/adapters/server/standalone.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "pnpm run build"
  },
  "files": [
    "dist/core",
    "dist/adapters",
    "dist/providers",
    "dist/tools",
    "dist/skills",
    "dist/models-catalog.js",
    "dist/agent.js",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "LICENSE"
  ],
  "keywords": [
    "ai-agent",
    "headless-agent",
    "llm-agent",
    "ai-cli",
    "ai-automation",
    "agent-framework",
    "headless-automation",
    "terminal-ai",
    "openai-agent",
    "claude-agent",
    "anthropic-agent",
    "multi-provider-llm",
    "devops-automation",
    "docker-agent",
    "chatgpt-cli"
  ],
  "author": "Hashan Wickramasinghe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hashangit/zclaw.git"
  },
  "bugs": {
    "url": "https://github.com/hashangit/zclaw/issues"
  },
  "homepage": "https://github.com/hashangit/zclaw#readme",
  "description": "A headless AI agent framework with CLI, SDK, and server adapters — skills, multi-provider LLM support, and Docker-native deployment.",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@mozilla/readability": "^0.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^16.4.7",
    "inquirer": "^13.2.2",
    "jsdom": "^28.0.0",
    "nodemailer": "^8.0.0",
    "openai": "^6.18.0",
    "ora": "^9.3.0",
    "playwright": "^1.58.2",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.2.1",
    "@types/nodemailer": "^7.0.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}