{
  "name": "zclaw-core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zclaw": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "pnpm run build",
    "build:bin:macos-arm64": "pkg dist/index.js --target node20-macos-arm64 --output bin/zclaw-macos-arm64 --config package.json",
    "build:bin:macos-x64": "pkg dist/index.js --target node20-macos-x64 --output bin/zclaw-macos-x64 --config package.json",
    "build:bin:linux-x64": "pkg dist/index.js --target node20-linux-x64 --output bin/zclaw-linux-x64 --config package.json",
    "build:bin:linux-arm64": "pkg dist/index.js --target node20-linux-arm64 --output bin/zclaw-linux-arm64 --config package.json"
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "keywords": [
    "ai-agent",
    "headless-agent",
    "llm-agent",
    "ai-cli",
    "ai-automation",
    "agent-framework",
    "headless-automation",
    "terminal-ai",
    "openai-agent",
    "claude-agent",
    "anthropic-agent",
    "multi-provider-llm",
    "devops-automation",
    "docker-agent",
    "chatgpt-cli"
  ],
  "author": "Hashan Wickramasinghe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hashangit/zclaw.git"
  },
  "bugs": {
    "url": "https://github.com/hashangit/zclaw/issues"
  },
  "homepage": "https://github.com/hashangit/zclaw#readme",
  "description": "A lightweight AI agent CLI tool that brings the power of LLMs to your terminal.",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@mozilla/readability": "^0.6.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^16.4.7",
    "inquirer": "^13.2.2",
    "jsdom": "^28.0.0",
    "nodemailer": "^8.0.0",
    "openai": "^6.18.0",
    "ora": "^9.3.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.2.1",
    "@types/nodemailer": "^7.0.9",
    "@yao-pkg/pkg": "^6.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}